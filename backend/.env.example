# Server Configuration
PORT=3001

# Demo Mode (set to true to use mock data instead of real watsonx.ai API)
DEMO_MODE=true

# IBM watsonx.ai Configuration (only needed if DEMO_MODE=false)
WATSONX_API_KEY=your_api_key_here
WATSONX_PROJECT_ID=your_project_id_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_MODEL=ibm/granite-13b-instruct-v2

# IBM Bob QA Configuration
IBM_BOB_STRICT_MODE=true